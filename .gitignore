# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (any app under monorepo)
**/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Go binaries
*.exe
*.exe~

# Go debug scripts (must be in cmd/<toolname>/ subdir, not backend root)
backend/check_*.go
backend/*_cmd.go
backend/temp_*.go
backend/debug_*.go

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# backend runtime logs
backend/out.log
backend/*.log
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# DB backups (kept local only — GitHub 50MB limit)
backup/*.dump
backup/*.sql
!backup/README.md
